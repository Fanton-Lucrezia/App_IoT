<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="160dp"
    android:background="@color/lilla_dark"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp">

    <!-- Bordo cerchio sul FrameLayout, non sulla ShapeableImageView -->
    <FrameLayout
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="14dp"
        android:padding="2dp"
        android:background="@drawable/bg_circle_border_white">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/navHeaderAvatar"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_person"
            android:padding="10dp"
            android:scaleType="centerCrop"
            app:tint="@color/lilla_dark"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Circle" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/navHeaderUsername"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Utente"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/navHeaderRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Utente"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp" />

    </LinearLayout>

</LinearLayout>