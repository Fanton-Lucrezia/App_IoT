<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.ProgettoAppIoT" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_darkmode</item>
        <item name="colorPrimaryVariant">@color/accent_darkmode</item>
        <item name="colorOnPrimary">@color/background_dark</item>

        <item name="colorSecondary">@color/accent_darkmode</item>
        <item name="colorOnSecondary">@color/background_dark</item>

        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_primary_dark</item>
        <item name="colorSurfaceVariant">@color/surface_variant_dark</item>

        <item name="android:colorBackground">@color/background_dark</item>
        <item name="android:textColorPrimary">@color/text_primary_dark</item>
        <item name="android:textColorSecondary">@color/text_secondary_dark</item>
        <item name="android:textColor">@color/text_primary_dark</item>
        <item name="android:textColorHint">@color/text_secondary_dark</item>
        <item name="android:editTextColor">@color/text_primary_dark</item>

        <item name="android:windowBackground">@color/background_dark</item>
        <!-- Toolbar notte: viola scuro, non nero piatto -->
        <item name="android:statusBarColor">@color/toolbar_night</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <style name="TextAppearance.DOORmotic.Toolbar" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

</resources>