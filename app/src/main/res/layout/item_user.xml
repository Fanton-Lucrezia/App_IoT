<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginBottom="10dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/lilla_light"
    app:strokeColor="@color/lilla_dark"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="10dp">

        <!-- Avatar iniziale -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp">

            <TextView
                android:id="@+id/tvUserInitial"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/lilla_dark"
                android:background="@drawable/bg_avatar" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivUserAvatar"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Circle" />

        </FrameLayout>

        <!-- Info utente -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textStyle="bold"
                android:textColor="@color/lilla_dark"
                android:layout_marginBottom="6dp" />

            <!-- Chip ruolo + chip accesso -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipUserRole"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:textSize="11sp"
                    android:layout_marginEnd="6dp"
                    app:chipMinHeight="28dp"
                    style="@style/Widget.Material3.Chip.Assist" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipUserAccess"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:textSize="11sp"
                    app:chipMinHeight="28dp"
                    style="@style/Widget.Material3.Chip.Assist" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvResetRequest"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔑 Richiesta cambio password"
                android:textSize="13sp"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnApproveReset"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅ Sì"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRejectReset"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="🚫 No"
                    android:visibility="gone" />

            </LinearLayout>
        </LinearLayout>

        <!-- Switch accesso porta -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchUserAccess"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp" />

        <!-- Cestino elimina -->
        <ImageButton
            android:id="@+id/btnDeleteUser"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_delete"
            android:contentDescription="Elimina utente"
            android:padding="6dp"
            app:tint="@color/error" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>