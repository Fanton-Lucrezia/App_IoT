<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lilla_surface"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/storicoToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/lilla_dark"
        android:elevation="4dp"
        app:title="Storico Accessi"
        app:titleTextColor="@color/white"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/white" />

    <!-- Info: quanti accessi mostrati -->
    <TextView
        android:id="@+id/tvStoricoInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:paddingStart="16dp"
        android:text="Caricamento..."
        android:textColor="@color/gray_medium"
        android:textSize="12sp" />

    <!-- Lista accessi -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerStorico"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/progressStorico"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="24dp"
        android:visibility="gone"
        android:indeterminateTint="@color/lilla_dark" />

</LinearLayout>
